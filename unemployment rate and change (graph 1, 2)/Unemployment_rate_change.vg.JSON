{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Rate of change in total unemployment",
  "description": "percentage change in Malaysian unemployment",
  "data": {
    "url": "unem_rate_change.csv"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "year", "type": "temporal",
      "axis": {
        "domain": false,
        "ticks": false,
        "labelAngle": 0,
        "labelPadding": 4
      }
    },
    "y": {
      "field": "unemployment rate change", "type": "quantitative",
      "axis": {
        "gridColor": {
          "condition": {"test": "datum.value === 0", "value": "black"},
          "value": "#ddd"
        }
      }
    }
  }
}
