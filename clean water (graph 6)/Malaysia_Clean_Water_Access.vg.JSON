{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": { "text": "Clean Water Accessibility" },
    "description": "Clean water accessibility in Malaysia",
    "data": {
        "url": "clean water (graph 6)/water2.csv"
    },

        "params": [
        {
        "name": "brush",
        "select": {
            "type": "interval",
            "encodings": ["x"]
        }
    }
],
    "vconcat": [
        {
            "width": 500,
            "height": 120,

            "mark": {
            "type": "line",
            "point": true
        },
        

        "encoding": {
            "x": { "field": "year", "type": "temporal" },
            "y": { "field": "percentage population", "type": "quantitative",
            "scale": {
                "domain": [90, 100]
            } 
        },
        "tooltip": [
            {"field": "year", "type": "temporal", "format": "%Y"},
            {"field": "percentage population"}
        ]
    }
},

{
    "width": 500,
    "height": 200,

    "mark": {
        "type": "line",
        "opacity": 0.8
    },

"encoding": {
        "x": {
          "field": "year",
          "type": "temporal"
        },

        "y": {
          "field": "percentage population",
          "type": "quantitative",
          "scale": {
            "domain": [0, 100]
          }
        }
      },
      "transform": [
        {
          "filter": {
            "param": "brush"
          }
    }
  ]
}
    ]
}
