{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": { "text": "Electricity Accessibility in Malaysia" },
    "description": "Electricity accessibility in Malaysia",
    "data": {
        "url": "electricity2.csv"
    },

    "vconcat": [
        {
            "width": 500,
            "height": 120,

            "mark": {
            "type": "line",
            "point": true
        },
        

        "encoding": {
            "x": { "field": "year", "type": "ordinal" },
            "y": { "field": "percentage population", "type": "quantitative",
            "scale": {
                "domain": [90, 100]
            } 
        },
        "tooltip": [
            {"field": "year"},
            {"field": "percentage population"}
        ]
    }
},

{
    "width": 500,
    "height": 200,

    "mark": {
        "type": "line",
        "opacity": 0.8
    },

    "params": [
        {
        "name": "brush",
        "select": {
            "type": "interval",
            "encodings": ["x"]
        }
    }
],
"encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },

        "y": {
          "field": "percentage population",
          "type": "quantitative",
          "scale": {
            "domain": [0, 100]
          }
        }
      }
    }
  ]
}
