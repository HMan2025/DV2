{
"$schema": "https://vega.github.io/schema/vega-lite/v5.json",
"width": 800,
"height": 400,
"title": "mean household income as of 01-01-2022",
"projection": {"type": "mercator"},

"data": {
"url":
"household income poverty (graph 4, 5)/ne_10m_admin_1_states_provinces.json",
"format": {"type": "topojson", "feature":
"ne_10m_admin_1_states_provinces"}
},

"transform": [
    {
        "filter": "datum.properties.admin === 'Malaysia'"
    },

    {
        "lookup": "properties.name",

        "from":{
            "data":{
                "url": "household income poverty (graph 4, 5)/hh_income.csv"
            },
            "key": "state",

            "fields": ["mean income"]
        }
    }
],

"mark": {
    "type": "geoshape",
    "stroke": "white",
    "strokeWidth": 1
},

"encoding": {
    "color": {
        "field": "mean income",
        "type": "quantitative",
        "title": "mean income (RM)",

        "scale": {
            "scheme": "viridis"
        }
    },
    "tooltip": [
        {
            "field": "properties.name",
            "title": "state"
        },

        {
            "field": "mean income",
            "title": "mean income"
        }
    ]
}
}